---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const categoryLabels: Record<string, string> = {
  'cost-guides': 'Cost Guides',
  'contractor-tips': 'Contractor Tips',
  'hvac': 'HVAC',
  'roofing': 'Roofing',
  'plumbing': 'Plumbing',
  'electrical': 'Electrical',
  'homeowner-basics': 'Homeowner Basics',
  'home-warranty': 'Home Warranty',
  'insurance': 'Insurance',
  'pest-control': 'Pest Control',
};

const categories = [...new Set(allPosts.map(p => p.data.category))].sort();
---

<BaseLayout
  title="Home Repair & Improvement Guides"
  description="Honest, research-backed guides for American homeowners. Cost estimates, contractor tips, troubleshooting help, and advice you can trust."
>
  <section class="blog-hero">
    <div class="container">
      <h1>Guides for American Homeowners</h1>
      <p>Every article is researched using real homeowner experiences, verified industry data, and official government sources. We write for people who want honest answers, not sales pitches.</p>
    </div>
  </section>

  <section class="blog-listing">
    <div class="container">
      <div class="filter-bar">
        <button class="filter-btn active" data-category="all">All</button>
        {categories.map(cat => (
          <button class="filter-btn" data-category={cat}>
            {categoryLabels[cat] || cat}
          </button>
        ))}
      </div>

      <p class="results-count">
        Showing <span id="count">{sortedPosts.length}</span> guides
      </p>

      <div class="blog-grid">
        {sortedPosts.map(post => (
          <div class="blog-card-wrapper" data-category={post.data.category}>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              readTime={post.data.readTime}
              slug={post.id}
            />
          </div>
        ))}
      </div>

      <p class="no-results" style="display:none;">No guides found for this category yet. Check back soon!</p>
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.blog-card-wrapper');
  const countEl = document.getElementById('count');
  const noResults = document.querySelector('.no-results') as HTMLElement;

  // Check URL param on load
  const urlParams = new URLSearchParams(window.location.search);
  const initialCategory = urlParams.get('category');

  function filterByCategory(category: string) {
    let visible = 0;

    buttons.forEach(btn => {
      btn.classList.toggle('active', btn.getAttribute('data-category') === category);
    });

    cards.forEach(card => {
      const el = card as HTMLElement;
      if (category === 'all' || el.dataset.category === category) {
        el.style.display = '';
        visible++;
      } else {
        el.style.display = 'none';
      }
    });

    if (countEl) countEl.textContent = String(visible);
    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category') || 'all';
      filterByCategory(cat);
      // Update URL without reload
      const url = new URL(window.location.href);
      if (cat === 'all') {
        url.searchParams.delete('category');
      } else {
        url.searchParams.set('category', cat);
      }
      window.history.replaceState({}, '', url.toString());
    });
  });

  // Apply initial filter from URL
  if (initialCategory && initialCategory !== 'all') {
    filterByCategory(initialCategory);
  }
</script>

<style>
  .blog-hero {
    background: var(--color-primary-dark);
    color: white;
    padding: 3rem 0;
    text-align: center;
  }

  .blog-hero h1 {
    color: white;
    margin-bottom: 0.75rem;
  }

  .blog-hero p {
    color: #93c5fd;
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.05rem;
  }

  .blog-listing {
    padding: 3rem 0;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    justify-content: center;
  }

  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    background: var(--color-bg);
    color: var(--color-text-light);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .filter-btn.active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .results-count {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .no-results {
    text-align: center;
    color: var(--color-text-light);
    font-size: 1.05rem;
    padding: 3rem 0;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }

    .filter-bar {
      gap: 0.375rem;
    }

    .filter-btn {
      font-size: 0.8rem;
      padding: 0.4rem 0.75rem;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
